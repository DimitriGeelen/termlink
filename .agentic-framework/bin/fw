        print()

# Research artifacts (T-633)
reports_dir = os.path.join(project_root, 'docs', 'reports')
if os.path.isdir(reports_dir):
    tid_lower = task_id.lower().replace('-', '')
    artifacts = []
    for fn in sorted(os.listdir(reports_dir)):
