        ;;
    search)
        # Check for --semantic or --hybrid flags
        SEARCH_MODE="keyword"
        SEARCH_ARGS=()
        for arg in "$@"; do
            case "$arg" in
                --semantic) SEARCH_MODE="semantic" ;;
                --hybrid)   SEARCH_MODE="hybrid" ;;
