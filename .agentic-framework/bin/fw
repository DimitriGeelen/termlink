slug = re.sub(r'[^a-z0-9_-]', '-', slug)
cron_source = os.path.join(project_root, '.context', 'cron', 'agentic-audit.crontab')
cron_install = f'/etc/cron.d/agentic-audit-{slug}'

lines = [
