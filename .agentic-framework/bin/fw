            FW_TASK_ARCHIVE_ARGS="$*" python3 - << 'PYTASK_ARCHIVE'
import os, sys, re, shlex, subprocess

args = shlex.split(os.environ.get('FW_TASK_ARCHIVE_ARGS', ''))
dry_run = False
verbose = False
i = 0
while i < len(args):
    if args[i] in ('-n', '--dry-run'):
        dry_run = True; i += 1
    elif args[i] in ('-v', '--verbose'):
