import json
with open('$EF_SETTINGS') as f:
    data = json.load(f)
hooks = data.get('hooks', {})
for event, entries in hooks.items():
    for e in entries:
        matcher = e.get('matcher', '*')
        for h in e.get('hooks', []):
            cmd = h.get('command', '').split('/')[-1].split()[0]
            print(f'  {event:15s} [{matcher or \"*\":20s}] → {cmd}')
" 2>/dev/null
                else
