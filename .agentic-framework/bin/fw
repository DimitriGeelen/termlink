                    exit 1
                fi
                python3 -c "
import yaml, subprocess, time, sys, os

data = yaml.safe_load(open('$_cron_registry'))
job = None
for j in data.get('jobs', []):
    if j.get('id') == '$_job_id':
        job = j
        break

if not job:
