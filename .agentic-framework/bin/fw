            esac
        done
        SEARCH_TERM="${SEARCH_ARGS[*]:-}"
        if [ -z "$SEARCH_TERM" ]; then
            echo -e "${RED}Usage: fw search [--semantic|--hybrid] <query>${NC}"
            exit 1
        fi
