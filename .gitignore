.context/approvals/

# Framework symlink (machine-specific)
.agentic-framework

# fw upgrade rollback backup — machine-local, never tracked
.agentic-framework.rollback/

# Vendored TermLink binary (machine-specific, per-project isolation)
.termlink/bin/

# Claude Code backup (T-1271: include .bak.T-XXX suffix variants)
.claude/settings.json.bak
.claude/settings.json.bak.*

# Playwright MCP dev artifacts (L-028)
.playwright-mcp/

# Root-level screenshots (dev scratch)
/*.png

# Ephemeral session state (L-028)
.context/working/.tool-counter
.context/working/.edit-counter
.context/working/.new-file-counter
.context/working/.budget-status
.context/working/.budget-gate-counter
